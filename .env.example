# Vercel Analytics - leitura de dados no painel admin
# Gere o token em: https://vercel.com/account/tokens
VITE_VERCEL_TOKEN=seu_token_aqui

# ID do projeto (Vercel → seu projeto → Settings → General → Project ID)
VITE_VERCEL_PROJECT_ID=prj_xxxxxxxxxxxxxx

# ID do time (opcional, só se o projeto estiver num team)
# VITE_VERCEL_TEAM_ID=team_xxxxxxxxxxxxxx
