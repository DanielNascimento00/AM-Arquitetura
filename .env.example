# Vercel Analytics - leitura de dados no painel admin
# Gere o token em: https://vercel.com/account/tokens
# IMPORTANTE: sem o prefixo VITE_ — variáveis server-side não devem ser expostas no bundle
VERCEL_TOKEN=seu_token_aqui

# ID do projeto (Vercel → seu projeto → Settings → General → Project ID)
VERCEL_PROJECT_ID=prj_xxxxxxxxxxxxxx

# ID do time (opcional, só se o projeto estiver num team)
# VERCEL_TEAM_ID=team_xxxxxxxxxxxxxx

# Redis usado por visitas e leads do formulario
# Exemplo: rediss://default:senha@host:6379
STORAGE_REDIS_URL=rediss://default:senha@host:6379

# Autenticação do painel admin
# Email e senha do único usuário administrador
ADMIN_EMAIL=seu@email.com
ADMIN_PASSWORD=suasenhaforte
# Segredo usado para assinar o token de sessão (gere uma string aleatória longa, ex: openssl rand -hex 32)
ADMIN_SECRET=uma_string_aleatoria_e_longa_aqui

# Vercel Blob usado para salvar as fotos do portfolio
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxx

# Resend — disparo de email ao receber novo lead pelo formulário
# Crie a chave em: https://resend.com/api-keys
# Se ausente, o email é silenciosamente ignorado (lead ainda é salvo no Redis)
RESEND_API_KEY=re_xxxxxxxxxxxxxx
# Remetente do email (formato: "Nome <email@dominio.com>")
RESEND_FROM=AM Arquitetura <noreply@seudominio.com>

# URL base do site (usada no botão "Ver no Painel Admin" do email)
ADMIN_URL=https://seu-dominio.vercel.app/admin
